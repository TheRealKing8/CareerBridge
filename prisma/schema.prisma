// CareerBridge — Phase 1 schema
//
// Provider: SQLite (file-based, dev). To swap to PostgreSQL or MySQL later,
// change `provider` and `DATABASE_URL` only. The schema uses no
// SQLite-specific features.
//
// 7 tables: User, StudentProfile, EmployerProfile, Job, Application,
// SavedJob, Notification.
//
// IMPORTANT — SQLite + Prisma limitation:
// Prisma's SQLite connector does not support `enum` blocks. Each
// enum-shaped column below is a `String` with the allowed values
// documented in a comment, and the application layer (Zod validators
// at the API boundary) enforces the membership. When we move to
// Postgres for production we can promote these back to real `enum`
// types — no application-level changes needed because the values
// already match.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Models ─────────────────────────────
//
// String enum columns (validated by Zod):
//
// User.role:
//   "STUDENT" | "EMPLER" | "ADMIN"
//
// User.status:
//   "PENDING" | "ACTIVE" | "SUSPENDED"
//
// Job.type:
//   "INTERNSHIP" | "ATTACHMENT" | "GRADUATE_TRAINEE"
//   | "FULL_TIME" | "PART_TIME" | "CONTRACT"
//
// Job.status:
//   "DRAFT" | "OPEN" | "CLOSED" | "EXPIRED"
//
// Application.status:
//   "SUBMITTED" | "UNDER_REVIEW" | "SHORTLISTED"
//   | "REJECTED" | "WITHDRAWN"
//
// Notification.type:
//   "APPLICATION_STATUS" | "NEW_APPLICANT" | "JOB_APPROVED"
//   | "JOB_REJECTED" | "GENERIC"

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  fullName      String
  role          String     // STUDENT | EMPLOYER | ADMIN
  status        String     @default("PENDING")  // PENDING | ACTIVE | SUSPENDED
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  studentProfile  StudentProfile?
  employerProfile EmployerProfile?
  notifications   Notification[]

  @@index([role, status])
}

model StudentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  university     String?
  course         String?
  graduationYear Int?
  phone          String?
  bio            String?
  cvUrl          String?
  linkedinUrl    String?
  githubUrl      String?
  portfolioUrl   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  savedJobs    SavedJob[]

  @@index([graduationYear])
  @@index([course])
}

model EmployerProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  companyName    String
  companyWebsite String?
  companyLogoUrl String?
  industry       String?
  companySize    String?
  description    String?
  location       String?
  verified       Boolean   @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@index([industry])
  @@index([verified])
}

model Job {
  id             String    @id @default(cuid())
  employerId     String
  title          String
  description    String
  type           String    // INTERNSHIP | ATTACHMENT | GRADUATE_TRAINEE | FULL_TIME | PART_TIME | CONTRACT
  location       String?
  remote         Boolean   @default(false)
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?   @default("KES")
  deadline       DateTime?
  status         String    @default("DRAFT")  // DRAFT | OPEN | CLOSED | EXPIRED
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employer     EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  applications Application[]
  savedBy      SavedJob[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([type])
  @@index([employerId, status])
}

model Application {
  id          String   @id @default(cuid())
  jobId       String
  studentId   String
  coverLetter String?
  cvUrl       String?
  status      String   @default("SUBMITTED")  // SUBMITTED | UNDER_REVIEW | SHORTLISTED | REJECTED | WITHDRAWN
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job     Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([jobId, studentId])
  @@index([studentId, status])
  @@index([jobId, status])
}

model SavedJob {
  id        String   @id @default(cuid())
  studentId String
  jobId     String
  savedAt   DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job     Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([studentId, jobId])
  @@index([studentId, savedAt(sort: Desc)])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // APPLICATION_STATUS | NEW_APPLICANT | JOB_APPROVED | JOB_REJECTED | GENERIC
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
}