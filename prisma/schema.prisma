// CareerBridge — Phase 1 schema
//
// Provider: MariaDB / MySQL via XAMPP (dev). All schema features used
// below are standard SQL — switching to PostgreSQL for production later
// is a one-line `provider` change.
//
// 10 tables: User, Account, Session, VerificationToken, StudentProfile,
// EmployerProfile, Job, Application, SavedJob, Notification.
//
// Prisma does not render MySQL `ENUM` types when the database provider
// supports them, but we deliberately use `String` here so the column
// type stays portable across MariaDB / MySQL / PostgreSQL. Membership
// is enforced at the API boundary by Zod validators; the allowed values
// are documented inline below.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Models ─────────────────────────────
//
// String enum columns (validated by Zod):
//
// User.role:
//   "STUDENT" | "EMPLOYER" | "EMPLOYEE" | "ADMIN"
//
// User.status:
//   "PENDING" | "ACTIVE" | "SUSPENDED"
//
// Job.type:
//   "INTERNSHIP" | "ATTACHMENT" | "GRADUATE_TRAINEE"
//   | "FULL_TIME" | "PART_TIME" | "CONTRACT"
//
// Job.status:
//   "DRAFT" | "OPEN" | "CLOSED" | "EXPIRED"
//
// Application.status:
//   "SUBMITTED" | "UNDER_REVIEW" | "SHORTLISTED"
//   | "REJECTED" | "WITHDRAWN"
//
// Notification.type:
//   "APPLICATION_STATUS" | "NEW_APPLICANT" | "JOB_APPROVED"
//   | "JOB_REJECTED" | "GENERIC"

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  passwordHash     String
  fullName         String
  role             String     // STUDENT | EMPLOYER | ADMIN
  status           String     @default("PENDING")  // PENDING | ACTIVE | SUSPENDED
  emailVerified    DateTime?
  passwordChangedAt DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  studentProfile  StudentProfile?
  employerProfile EmployerProfile?
  employeeProfile EmployeeProfile?
  notifications   Notification[]

  // NextAuth relations. Empty in our JWT flow but required by the adapter.
  accounts Account[]
  sessions Session[]

  @@index([role, status])
}

// NextAuth Prisma adapter tables.
// `Account` and `Session` stay empty in our JWT-only flow, but the adapter
// contract requires the models to exist. `VerificationToken` is reserved
// for Phase 2c (email verification / password reset).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StudentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  university     String?
  course         String?
  graduationYear Int?
  phone          String?
  bio            String?
  cvUrl          String?
  linkedinUrl    String?
  githubUrl      String?
  portfolioUrl   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  savedJobs    SavedJob[]

  @@index([graduationYear])
  @@index([course])
}

model EmployerProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  companyName    String
  companyWebsite String?
  companyLogoUrl String?
  industry       String?
  companySize    String?
  description    String?
  location       String?
  verified       Boolean   @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@index([industry])
  @@index([verified])
}

model EmployeeProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentJobTitle   String?
  currentCompany    String?
  yearsOfExperience Int?
  skills            String?  // Comma-separated for now. Skill table is a future cleanup.
  phone             String?
  bio               String?
  cvUrl             String?
  linkedinUrl       String?
  githubUrl         String?
  portfolioUrl      String?
  location          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([yearsOfExperience])
  @@index([location])
}

model Job {
  id             String    @id @default(cuid())
  employerId     String
  title          String
  description    String
  type           String    // INTERNSHIP | ATTACHMENT | GRADUATE_TRAINEE | FULL_TIME | PART_TIME | CONTRACT
  location       String?
  remote         Boolean   @default(false)
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?   @default("KES")
  deadline       DateTime?
  status         String    @default("DRAFT")  // DRAFT | OPEN | CLOSED | EXPIRED
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employer     EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  applications Application[]
  savedBy      SavedJob[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([type])
  @@index([employerId, status])
}

model Application {
  id               String   @id @default(cuid())
  jobId            String
  studentId        String?  // One of {studentId, employeeProfileId} is non-null. Enforced at the application layer.
  employeeProfileId String?
  coverLetter      String?
  cvUrl            String?
  status           String   @default("SUBMITTED")  // SUBMITTED | UNDER_REVIEW | SHORTLISTED | REJECTED | WITHDRAWN
  appliedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student         StudentProfile?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  employeeProfile EmployeeProfile? @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@unique([jobId, studentId])
  @@unique([jobId, employeeProfileId])
  @@index([studentId, status])
  @@index([employeeProfileId, status])
  @@index([jobId, status])
}

model SavedJob {
  id        String   @id @default(cuid())
  studentId String
  jobId     String
  savedAt   DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job     Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([studentId, jobId])
  @@index([studentId, savedAt(sort: Desc)])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // APPLICATION_STATUS | NEW_APPLICANT | JOB_APPROVED | JOB_REJECTED | GENERIC
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
}